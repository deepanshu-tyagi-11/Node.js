// Basically event loop jo hota hai vo priority kia hisab se chalta hai..

// WHICH LIEN OF CODE RUN FIRST ... UDING THEIR PRIORITY....

console.log('1. Start of script');

Promise.resolve().then(() => console.log('2. Microtask 1'));

setTimeout(() => console.log('3. Timer 1'), 0);

const fs = require('fs');
fs.readFile('user-details.txt', () => console.log('4. I/O operation'));

setImmediate(() => console.log('5. Immediate 1'));

process.on('exit', (code) => {
  console.log('6. Exit event');
});

console.log('7. End of script');

// OUTPUT:
1. Start of script
7. End of script
2. Microtask 1
3. Timer 1
4. I/O operation
5. Immediate 1
6. Exit event


// EXPLANTION:

Priority in Node.js Event Loop:

Synchronous code
Microtasks (Promise.then, queueMicrotask)
Timers (setTimeout, setInterval)
I/O callbacks (fs.readFile)
setImmediate
Exit events

Remember:

Sync → Microtask → Timer → I/O → setImmediate → Exit



